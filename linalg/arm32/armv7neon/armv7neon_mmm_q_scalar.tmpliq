// vim: ft=arm

.{{label}}:
    vmov            s0, r3
    vdup.32         q0, d0[0]
    {% if flipped | default(false) %}
        {% for reg in range(from, to + 1) %}
            {{op}}    q{{reg}}, q{{reg}}, q0
        {% endfor %}
    {% else %}
        {% for reg in range(from, to + 1) %}
            {{op}}    q{{reg}}, q0, q{{reg}}
        {% endfor %}
    {% endif %}
    b .non_linear_loop
