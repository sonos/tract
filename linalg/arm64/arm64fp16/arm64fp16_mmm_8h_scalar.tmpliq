// vim: ft=arm

.{{label}}:
    add         x2, x0, #8
    ld1         {v0.h}[0], [ x2 ]
    dup         v0.8h, v0.h[0]
    {% if flipped | default(false) %}
        {% for reg in range(from, to + 1) %}
            {{op}}       v{{reg}}.8h, v{{reg}}.8h, v0.8h
        {% endfor %}
    {% else %}
        {% for reg in range(from, to + 1) %}
            {{op}}       v{{reg}}.8h, v0.8h, v{{reg}}.8h
        {% endfor %}
    {% endif %}

    b           .non_linear_loop

